{
  "api_key": "sk-or-v1-...",
  "base_url": "https://openrouter.ai/api/v1",
  "model": "google/gemini-2.5-pro",
  "disable_vision": false,
  "port": 8080,
  "ssl_port": 8443,
  "password": "optional_secure_password",
  "ssl_cert": "",
  "ssl_key": "",
  "compaction": {
    "auto": true,
    "tail_turns": 10,
    "preserve_recent_tokens": 4000,
    "reserved": 4000,
    "prune": true,
    "tool_truncation_limit": 2000
  },
  "mcp": {
    "servers": {
      "example-mcp-server": {
        "type": "local",
        "command": ["npx", "-y", "@modelcontextprotocol/server-everything"],
        "cwd": ".",
        "environment": {
          "EXAMPLE_KEY": "optional_env_vars"
        },
        "disabled": false
      }
    }
  }
}
